# Gmail credentials for the contact form (src/app/api/mail/route.ts)
# MAIL_PASS must be a Gmail App Password, not your regular account password:
# https://myaccount.google.com/apppasswords
MAIL_USER=your-gmail-address@gmail.com
MAIL_PASS=your-gmail-app-password
MAIL_RECEIVER=destination-email@example.com

# Groq API key for the AI chatbot (src/lib/chat/model.ts)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
